{
	"info": {
		"_postman_id": "match-service-api-tests",
		"name": "MatchService API Tests",
		"description": "Postman collection for testing MatchService REST API endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8083",
			"type": "string"
		},
		{
			"key": "matchId",
			"value": "",
			"type": "string"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "javascript",
				"exec": [
					"// Set default date range if not set",
					"if (!pm.environment.get('startDate')) {",
					"    const startDate = new Date();",
					"    startDate.setDate(startDate.getDate() - 1);",
					"    pm.environment.set('startDate', startDate.toISOString());",
					"}",
					"if (!pm.environment.get('endDate')) {",
					"    const endDate = new Date();",
					"    endDate.setDate(endDate.getDate() + 7);",
					"    pm.environment.set('endDate', endDate.toISOString());",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Get All Matches - Empty",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/matches",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "matches"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "javascript",
								"exec": [
									"pm.test('Response status is 200', function() {",
									"    pm.expect(pm.response.status).to.eq(200);",
									"});",
									"",
									"pm.test('Response is an array', function() {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Create Match (Database Setup)",
			"item": [
				{
					"name": "Create Match via Direct DB Insert",
					"description": "Note: There's no POST endpoint for creating matches. This is handled internally. Use SportMonks sync or direct DB insert."
				}
			]
		},
