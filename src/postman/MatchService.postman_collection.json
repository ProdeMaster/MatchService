		{
			"name": "Status Values Reference",
			"item": [
				{
					"name": "List All Valid Status Values",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/matches/status/NS",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "matches", "status", "NS"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "javascript",
								"exec": [
									"// Valid status values:",
									"// NS - Not Started",
									"// TBA - To Be Announced",
									"// INPLAY_1ST_HALF - First Half In Play",
									"// HT - Half Time",
									"// INPLAY_2ND_HALF - Second Half In Play",
									"// FT - Full Time",
									"// INPLAY_ET - Extra Time In Play",
									"// EXTRA_TIME_BREAK - Extra Time Break",
									"// INPLAY_ET_2ND_HALF - Extra Time Second Half",
									"// AET - After Extra Time",
									"// INPLAY_PENALTIES - Penalties In Play",
									"// PEN_BREAK - Penalty Break",
									"// FT_PEN - Full Time After Penalties",
									"// DELAYED - Delayed",
									"// POSTPONED - Postponed",
									"// SUSPENDED - Suspended",
									"// INTERRUPTED - Interrupted",
									"// AWARDED - Awarded",
									"// WO - Walk Over",
									"// CANCELLED - Cancelled",
									"// ABANDONED - Abandoned",
									"// DELETED - Deleted",
									"// AWAITING_UPDATES - Awaiting Updates",
									"",
									"pm.test('Valid status values can be queried', function() {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						}
					]
				}
			]
		}
	]
}
